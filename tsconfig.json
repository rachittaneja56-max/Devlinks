{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/(public)/page.js",
    "app/(public)/UpvoteButton.jsx",
    "app/(admin)/admin/page.js",
    "app/(admin)/admin/DeleteButton.jsx",
    "models/Resource.js",
    "app/layout.jsx"
, "app/api/resources/[id]/route.js", "app/api/resources/routes.js"  ],
  "exclude": [
    "node_modules"
  ]
}